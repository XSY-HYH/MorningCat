{
  "name": "morningcat-gui",
  "version": "1.0.0",
  "description": "MorningCat GUI - Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.morningcat.gui",
    "productName": "MorningCat",
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "webui/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "../MorningCat.WebUI/wwwroot/webui",
        "to": "webui"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}

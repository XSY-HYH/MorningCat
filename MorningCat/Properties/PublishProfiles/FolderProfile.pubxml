<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
	<PropertyGroup>
		<Configuration>Release</Configuration>
		<Platform>Any CPU</Platform>
		<PublishDir>D:\仓库\MorningCat\Core\v2.0-release-win-x64</PublishDir>
		<PublishProtocol>FileSystem</PublishProtocol>
		<_TargetId>Folder</_TargetId>
		<TargetFramework>net10.0</TargetFramework>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<SelfContained>true</SelfContained>
		<PublishSingleFile>false</PublishSingleFile>
		<PublishReadyToRun>false</PublishReadyToRun>
		<PublishTrimmed>false</PublishTrimmed>

		<!-- 新增：排除调试和诊断文件 -->
		<DebugType>none</DebugType>
		<DebugSymbols>false</DebugSymbols>
		<IncludeCrashDump>false</IncludeCrashDump>
		<IncludeSymbols>false</IncludeSymbols>
		<CrashDumpSupport>false</CrashDumpSupport>
		<DebuggerSupport>false</DebuggerSupport>
	</PropertyGroup>

	<!-- 新增：发布后删除 createdump.exe 和其他调试文件 -->
	<Target Name="RemoveUnnecessaryFiles" AfterTargets="Publish">
		<!-- 删除 createdump.exe -->
		<Delete Files="$(PublishDir)createdump.exe" Condition="Exists('$(PublishDir)createdump.exe')" />

		<!-- 删除崩溃转储文件 -->
		<Delete Files="$(PublishDir)*.dmp" Condition="Exists('$(PublishDir)*.dmp')" />

		<!-- 可选：删除其他不必要的文件 -->
		<Delete Files="$(PublishDir)*.runtimeconfig.json" Condition="Exists('$(PublishDir)*.runtimeconfig.json')" />
		<Delete Files="$(PublishDir)*.deps.json" Condition="Exists('$(PublishDir)*.deps.json')" />

		<Message Text="已清理 createdump.exe 和调试文件" Importance="high" />
	</Target>
</Project>
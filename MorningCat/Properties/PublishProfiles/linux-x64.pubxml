<?xml version="1.0" encoding="utf-8"?>
<Project>
	<PropertyGroup>
		<Configuration>Release</Configuration>
		<Platform>Any CPU</Platform>
		<PublishProtocol>FileSystem</PublishProtocol>
		<_TargetId>Folder</_TargetId>
		<TargetFramework>net10.0</TargetFramework>
		<RuntimeIdentifier>linux-x64</RuntimeIdentifier>
		<SelfContained>true</SelfContained>
		<PublishSingleFile>false</PublishSingleFile>
		<PublishReadyToRun>false</PublishReadyToRun>
		<PublishTrimmed>false</PublishTrimmed>

		<!-- 排除调试和诊断文件 -->
		<DebugType>none</DebugType>
		<DebugSymbols>false</DebugSymbols>
		<IncludeCrashDump>false</IncludeCrashDump>
		<IncludeSymbols>false</IncludeSymbols>
		<CrashDumpSupport>false</CrashDumpSupport>
		<DebuggerSupport>false</DebuggerSupport>
	</PropertyGroup>

	<!-- 发布后删除不必要的文件 -->
	<Target Name="RemoveUnnecessaryFiles" AfterTargets="Publish">
		<Delete Files="$(PublishDir)createdump" Condition="Exists('$(PublishDir)createdump')" />
		<Delete Files="$(PublishDir)*.dmp" Condition="Exists('$(PublishDir)*.dmp')" />
		<Delete Files="$(PublishDir)*.runtimeconfig.json" Condition="Exists('$(PublishDir)*.runtimeconfig.json')" />
		<Delete Files="$(PublishDir)*.deps.json" Condition="Exists('$(PublishDir)*.deps.json')" />
		<Message Text="已清理 createdump 和调试文件" Importance="high" />
	</Target>
</Project>